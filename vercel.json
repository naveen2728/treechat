{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*\\.(js|css|html))$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/tree.html"
    }
  ]
}
