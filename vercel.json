{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/tree.html",
      "dest": "/tree.html"
    },
    {
      "src": "/tree.js",
      "dest": "/tree.js"
    },
    {
      "src": "/tree.css",
      "dest": "/tree.css"
    },
    {
      "src": "/(.*)",
      "dest": "/tree.html"
    }
  ]
}
